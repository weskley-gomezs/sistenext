rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null && request.auth.uid != null;
    }
    
    function isAuthorized(ownerId) {
      return request.auth != null && ownerId != null && (
        request.auth.uid == ownerId || 
        (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.ownerId == ownerId)
      );
    }

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profiles: Users can read/write their own profile
    match /user_profiles/{userId} {
      allow get: if isAuthenticated() && request.auth.uid == userId;
      allow list: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Equipe: Security hardened lookup by email or organization authority
    match /equipe/{id} {
      allow get: if resource == null || (
        isAuthenticated() && (
          request.auth.token.email == resource.data.email || 
          isAuthorized(resource.data.ownerId)
        )
      );
      allow list: if true;
      allow write: if isAuthenticated() && isAuthorized(request.resource.data.ownerId);
    }

    // Configurations: Keyed by ownerId
    match /configuracoes/{ownerId} {
      allow get: if isAuthenticated() && isAuthorized(ownerId);
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && isAuthorized(ownerId);
    }

    // Application Collections: Strictly isolated by ownerId
    match /leads/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /empresas/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /clientes/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /projetos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /propostas/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /contratos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /financeiro/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /agenda/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /follow_ups/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /anotacoes/{id} {
      allow get: if isAuthenticated() && (
        resource == null || (
          isAuthorized(resource.data.ownerId) && (
            // Admin sees everything, Salesperson sees only theirs or linked to their leads
            !exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) ||
            get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role != 'Vendedor' ||
            resource.data.createdBy == request.auth.token.email ||
            resource.data.user == request.auth.token.email
          )
        )
      );
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /documentos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /logs/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /assinaturas_clientes/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /oportunidades/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /planejamentos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /nichos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /estrategias/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /conteudos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /prospeccoes/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /diagnosticos/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /projetosPromocionais/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /cases/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /ideias/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /relatorios/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }

    match /metas/{id} {
      allow get: if isAuthenticated() && (resource == null || isAuthorized(resource.data.ownerId));
      allow list: if isAuthenticated();
      allow write: if isAuthenticated() && (
        (resource == null || isAuthorized(resource.data.ownerId)) &&
        (request.resource == null || isAuthorized(request.resource.data.ownerId))
      );
    }
  }
}
