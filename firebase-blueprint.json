  "firestore": {
    "leads": {
      "schema": { "$ref": "#/entities/Lead" },
      "description": "Collection of business leads"
    },
    "empresas": {
      "schema": { "$ref": "#/entities/Empresa" },
      "description": "Collection of corporate entities"
    },
    "clientes": {
      "schema": { "$ref": "#/entities/Cliente" },
      "description": "Collection of converted active customers"
    },
    "projetos": {
      "schema": { "$ref": "#/entities/Projeto" },
      "description": "Collection of active projects"
    },
    "propostas": {
      "schema": { "$ref": "#/entities/Proposta" },
      "description": "Collection of formal business proposals"
    },
    "contratos": {
      "schema": { "$ref": "#/entities/Contrato" },
      "description": "Collection of customer contracts"
    },
    "financeiro": {
      "schema": { "$ref": "#/entities/Financeiro" },
