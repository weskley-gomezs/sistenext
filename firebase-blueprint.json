{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Representative or company in the sales pipeline",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "company": { "type": "string" },
        "representative": { "type": "string" },
        "phone": { "type": "string" },
        "whatsapp": { "type": "string" },
        "email": { "type": "string" },
        "instagram": { "type": "string" },
        "linkedin": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "site": { "type": "string" },
        "segment": { "type": "string" },
        "employeeCount": { "type": "integer" },
        "estimatedRevenue": { "type": "number" },
        "source": { "type": "string" },
        "entryDate": { "type": "string" },
        "notes": { "type": "string" },
        "status": { "type": "string" },
