    "Empresa": {
      "title": "Empresa",
      "description": "Registered organizations and partner companies",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "cnpj": { "type": "string" },
        "companyName": { "type": "string" },
        "tradingName": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "cep": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
